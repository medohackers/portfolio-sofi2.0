---
import { fetchLatestYouTubeVideo } from "@src/services/youtube";
import { YouTube } from "astro-embed";


const videoData = await fetchLatestYouTubeVideo();

// Handle case when no video is found
if (!videoData) {
  console.warn("No YouTube video available to display");
}

const { id: videoId, thumbnail, title } = videoData || { id: "", thumbnail: "", title: "" };
---

<script>
  import { loadVideo } from "@controllers/VideoModal.controller";
  loadVideo();
</script>

{
  videoData ? (
    <section class="youtube__modal__box">
      <div class="modal__close__button" />
      <div class="modal__container">
        <YouTube
          id={videoId}
          class="latestVideoEmbed"
          poster={thumbnail}
          title={title || "Latest YouTube Video"}
        />
      </div>
    </section>
  ) : (
    <section class="youtube__modal__box">
      <div class="modal__close__button" />
      <div class="modal__container">
        <p>No video available at the moment</p>
      </div>
    </section>
  )
}
<style is:inline>
  lite-youtube {
    min-width: 100%;
    height: 100%;
  }
</style>

<style lang="scss">
  .youtube__modal__box {
    position: fixed;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 1200;
  }
  .modal__close__button {
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.699);
  }
  .modal__container {
    position: absolute;
    width: 95%;
    max-width: 900px;
    height: 550px;
    overflow: hidden;
    border-radius: 12px;
    border: solid 2px #1d536e;
  }
  @media (max-width: 900px) {
    .modal__container {
      height: 500px;
    }
  }
  @media (max-width: 600px) {
    .modal__container {
      height: 400px;
    }
  }
  @media (max-width: 400px) {
    .modal__container {
      height: 350px;
    }
  }
</style>
